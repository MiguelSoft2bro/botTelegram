# OpenCode Telegram Bridge - Configuration
# Copy this file to .env and fill in the values

# ============================================
# TELEGRAM BOT TOKEN
# ============================================
# How to get it:
# 1. Open Telegram and search for @BotFather
# 2. Send /newbot
# 3. Choose a name (e.g., "My OpenCode Bot")
# 4. Choose a username (must end in "bot", e.g., "myopencode_bot")
# 5. Copy the token BotFather gives you
BOT_TOKEN=your_telegram_bot_token_here

# ============================================
# ALLOWED USER IDS
# ============================================
# Only these Telegram user IDs can use the bot (security)
# How to get your ID:
# 1. Search for @userinfobot in Telegram
# 2. Send /start
# 3. Copy the "Id" number
# Multiple IDs separated by comma: 123456789,987654321
ALLOWED_USER_IDS=your_user_id_here

# ============================================
# OPENCODE PORT (optional)
# ============================================
# Default port for OpenCode HTTP API
# Usually you don't need to change this
OPENCODE_PORT=4096

# ============================================
# NOTIFICATION GROUP ID (optional)
# ============================================
# For push notifications via a Telegram group
# How to set up:
# 1. Create a new group in Telegram
# 2. Add your bot to the group
# 3. Send /chatid in the group
# 4. Copy the ID here (usually negative number for groups)
# Set to 0 to disable
NOTIFICATION_GROUP_ID=0
